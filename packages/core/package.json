{
  "name": "@eco-linter/core",
  "version": "1.0.0",
  "description": "eco-linter analysis engine — rules, scoring, and reporters",
  "license": "MIT",
  "keywords": ["eco-linter", "green-code", "carbon", "energy", "eslint", "static-analysis", "sustainability"],
  "homepage": "https://eco-linter.vercel.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/zunaibimtiaz/eco-linter"
  },
  "files": ["dist"],
  "type": "module",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@typescript-eslint/parser": "^8.0.0",
    "@typescript-eslint/utils": "^8.0.0",
    "cosmiconfig": "^9.0.0",
    "cosmiconfig-typescript-loader": "^5.0.0",
    "glob": "^10.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  }
}
